.header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16px 0 12px;
}

.header-right {
  display: flex;
  align-items: baseline;
  gap: 12px;
}

.title {
  font-size: 22px;
  font-weight: 700;
}

.count {
  font-size: 13px;
  color: #8a857d;
}

.loading, .empty {
  text-align: center;
  padding: 60px 0;
  color: #8a857d;
}

.empty-hint {
  display: block;
  font-size: 13px;
  margin-top: 4px;
  color: #6b6660;
}

.article-list {
  margin-top: 8px;
}

.article-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #262626;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
}

.card-main {
  flex: 1;
  overflow: hidden;
}

.article-title {
  font-size: 16px;
  font-weight: 600;
  line-height: 1.4;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-meta {
  margin-top: 6px;
  font-size: 12px;
  color: #8a857d;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.site { color: #b5a48b; }
.author { color: #8a857d; }
.time { color: #7a7570; }
.words { color: #8a857d; }

.extraction-failed-badge {
  margin-top: 6px;
  font-size: 11px;
  color: #d4a543;
  background: #3d2e14;
  padding: 2px 8px;
  border-radius: 4px;
  display: inline-block;
}

.settings-link {
  font-size: 13px;
  color: #b5a48b;
}

.card-delete {
  padding: 8px;
  margin-left: 8px;
}

.delete-icon {
  font-size: 16px;
  color: #8a857d;
  font-weight: bold;
}

.pagination {
  display: flex;
  justify-content: space-between;
  padding: 16px 0;
}

.btn-page {
  background: #262626;
  color: #c5c0b8;
  border: 1px solid #333;
  border-radius: 6px;
}
