<view class="container">
  <view class="header">
    <view class="header-main">
      <text class="title">Inbox</text>
      <text class="count" wx:if="{{total > 0}}">{{total}}{{hasMore ? '+' : ''}} articles</text>
    </view>
    <view class="header-right">
      <text class="save-link" bindtap="openSave">+ Save</text>
      <text class="settings-link" bindtap="openSettings">Settings</text>
    </view>
  </view>

  <view wx:if="{{refreshing}}" class="refreshing">Refreshing...</view>

  <block wx:if="{{loading}}">
    <view class="loading">Loading...</view>
  </block>

  <block wx:elif="{{error}}">
    <view class="empty">
      <text>{{error}}</text>
      <button class="btn-page retry-button" bindtap="loadArticles" size="mini">Retry</button>
    </view>
  </block>

  <block wx:elif="{{!articles.length}}">
    <view class="empty">
      <text>No articles yet.</text>
      <text class="empty-hint">Save articles via the browser extension or web app.</text>
    </view>
  </block>

  <block wx:else>
    <view class="article-list">
      <view
        class="article-card"
        wx:for="{{articles}}"
        wx:key="id"
        bindtap="openArticle"
        data-id="{{item.id}}"
      >
        <view class="card-main">
          <text class="article-title">{{item.title}}</text>
          <view class="article-meta">
            <text wx:if="{{item.site_name}}" class="site">{{item.site_name}}</text>
            <text wx:if="{{item.author}}" class="author">by {{item.author}}</text>
            <text class="time">{{item.saved_at}}</text>
            <text wx:if="{{item.word_count}}" class="words">{{item.word_count}} words</text>
          </view>
          <view wx:if="{{item.extraction_failed}}" class="extraction-failed-badge">extraction failed</view>
        </view>
        <view class="card-delete" catchtap="confirmDelete" data-id="{{item.id}}">
          <text class="delete-icon">X</text>
        </view>
      </view>
    </view>

    <view class="pagination" wx:if="{{page > 1 || hasMore}}">
      <button class="btn-page" wx:if="{{page > 1}}" bindtap="prevPage" size="mini">Previous</button>
      <button class="btn-page" wx:if="{{hasMore}}" bindtap="nextPage" size="mini">Next</button>
    </view>
  </block>
</view>
