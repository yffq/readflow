.form {
  padding: 20px 0;
}

.form-group {
  margin-bottom: 20px;
}

.label {
  display: block;
  font-size: 14px;
  color: #8a857d;
  margin-bottom: 8px;
}

.input {
  width: 100%;
  height: 44px;
  background: #262626;
  border: 1px solid #333;
  border-radius: 8px;
  padding: 0 12px;
  color: #c5c0b8;
  font-size: 15px;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  height: 44px;
  background: #7b6e5d;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  margin-top: 10px;
}
