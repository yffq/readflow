.article-header {
  padding: 16px 0 20px;
  border-bottom: 1px solid #262626;
  margin-bottom: 20px;
}

.article-title { font-size: 20px; font-weight: 700; line-height: 1.4; }
.article-byline { margin-top: 8px; font-size: 13px; color: #8a857d; display: flex; gap: 12px; }
.site { color: #b5a48b; }

.original-link { margin-top: 12px; }
.original-label { font-size: 13px; color: #7b6e5d; background: #262626; padding: 6px 12px; border-radius: 6px; }

.article-body { font-size: 16px; line-height: 1.8; }

.p { margin-bottom: 16px; }

.h1 { font-size: 24px; font-weight: 700; margin: 20px 0 12px; line-height: 1.3; }
.h2 { font-size: 20px; font-weight: 700; margin: 18px 0 10px; line-height: 1.3; }
.h3 { font-size: 18px; font-weight: 600; margin: 16px 0 8px; line-height: 1.3; }
.h4 { font-size: 16px; font-weight: 600; margin: 14px 0 6px; }
.h5 { font-size: 15px; font-weight: 600; margin: 12px 0 6px; }
.h6 { font-size: 14px; font-weight: 600; margin: 10px 0 6px; }

.link { color: #b5a48b; text-decoration: underline; }
.strong { font-weight: 700; }
.em { font-style: italic; }
.ic { font-family: monospace; background: #2e2e2e; padding: 1px 5px; border-radius: 3px; font-size: 14px; }

.pre {
  background: #2e2e2e; padding: 12px 14px; border-radius: 6px; margin: 12px 0;
  font-size: 14px; line-height: 1.5; white-space: pre-wrap; word-break: break-all; overflow-x: auto;
}

.blockquote {
  border-left: 3px solid #b5a48b; padding: 8px 16px; margin: 12px 0; color: #8a857d;
}

.list { margin: 8px 0 16px; }
.li { display: flex; margin-bottom: 4px; }
.li-marker { color: #8a857d; margin-right: 4px; flex-shrink: 0; }

.article-img { width: 100%; margin: 12px 0; border-radius: 6px; }

.loading, .no-content { text-align: center; padding: 60px 0; color: #8a857d; }
.open-original-btn { margin-top: 12px; color: #b5a48b; text-decoration: underline; }
